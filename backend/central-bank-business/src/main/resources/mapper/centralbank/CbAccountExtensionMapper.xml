<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.centralbank.eplatform.mapper.CbAccountExtensionMapper">
    <resultMap id="CbAccountExtensionResult" type="com.centralbank.eplatform.domain.CbAccountExtension">
        <id property="id" column="id" />
        <result property="userId" column="user_id" />
        <result property="role" column="role" />
        <result property="officeCode" column="office_code" />
        <result property="officeName" column="office_name" />
        <result property="enabled" column="enabled" />
        <result property="createdAt" column="created_at" />
        <result property="updatedAt" column="updated_at" />
    </resultMap>

    <select id="countAccountExtensions" resultType="int">
        select count(1) from cb_account_extension
    </select>

    <select id="selectByUserId" parameterType="long" resultMap="CbAccountExtensionResult">
        select * from cb_account_extension where user_id = #{userId}
    </select>
</mapper>
