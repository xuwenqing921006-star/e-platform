# Backend runtime environment template for direct jar deployment.
# Do not commit real values. Keep real values in server-local environment or .env.

SERVER_PORT=8003
DB_URL=jdbc:mysql://127.0.0.1:3306/central_bank_e_platform?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=GMT%2B8
DB_USERNAME=central_bank
DB_PASSWORD=change-me-mysql-app-password

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=change-me-redis-password

APP_STORAGE_ROOT=/data/central-bank-e-platform/uploads
APP_JWT_SECRET=change-me-strong-random-jwt-secret
APP_JWT_EXPIRE_MINUTES=30

DRUID_LOGIN_USERNAME=change-me-druid-user
DRUID_LOGIN_PASSWORD=change-me-druid-password
DRUID_STAT_ENABLED=false
DRUID_WEB_STAT_ENABLED=false

REFERER_ENABLED=true
REFERER_ALLOWED_DOMAINS=example.gov.cn
APP_CORS_ALLOWED_ORIGINS=

SPRINGDOC_ENABLED=false
