# RuoYi admin frontend environment template.
# Production is served under /admin/ and uses /prod-api through Nginx.

VUE_APP_TITLE=央行 E 平台
VUE_APP_BASE_API=/prod-api
VUE_APP_PUBLIC_PATH=/admin/

# Local dev only: vue.config.js proxies VUE_APP_BASE_API to this backend.
VUE_APP_BACKEND_PROXY_TARGET=http://localhost:8003
port=5176
