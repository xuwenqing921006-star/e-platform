# Production Docker Compose environment template.
# Do not commit real values. Create the server-local .env from this template.

MYSQL_ROOT_PASSWORD=change-me-mysql-root-password
MYSQL_DATABASE=central_bank_e_platform
MYSQL_USER=central_bank
MYSQL_PASSWORD=change-me-mysql-app-password

REDIS_PASSWORD=change-me-redis-password

APP_JWT_SECRET=change-me-strong-random-jwt-secret
APP_JWT_EXPIRE_MINUTES=30

DRUID_LOGIN_USERNAME=change-me-druid-user
DRUID_LOGIN_PASSWORD=change-me-druid-password
DRUID_STAT_ENABLED=false
DRUID_WEB_STAT_ENABLED=false

REFERER_ENABLED=true
REFERER_ALLOWED_DOMAINS=example.gov.cn
APP_CORS_ALLOWED_ORIGINS=

SPRINGDOC_ENABLED=false
HTTP_PORT=80
